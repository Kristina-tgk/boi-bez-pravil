class Fighter {
  constructor(name, avatar) {
    this.name = name;
    this.avatar = avatar;
    this.hp = 100;
    this.damage = 10;
    this.wins = 0;
  }

  attack(enemy) {
    const hit = Math.floor(Math.random() * this.damage) + 5;
    enemy.hp -= hit;

    if (enemy.hp < 0) {
      enemy.hp = 0;
    }

    return hit;
  }

  heal(points) {
    this.hp += points;
    if (this.hp > 100) {
      this.hp = 100;
    }
  }

  isAlive() {
    return this.hp > 0;
  }
}

const fighter1 = new Fighter("Kristena", "avatar1.png");
